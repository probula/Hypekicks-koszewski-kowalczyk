<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
<ScrollView
    android:id="@+id/formScroll"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    >
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">
    <EditText
        android:id="@+id/etId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="podaj id"
        android:inputType="text"/>
    <EditText
        android:id="@+id/etBrand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="brand"
        android:inputType="text" />

    <EditText
        android:id="@+id/etModelName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="modelName"
        android:inputType="text" />

    <EditText
        android:id="@+id/etReleaseYear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="releaseYear"
        android:inputType="number" />

    <EditText
        android:id="@+id/etResellPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="resellPrice"
        android:inputType="number" />

    <EditText
        android:id="@+id/etImageUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="imageUrl"
        android:inputType="textUri" />

    <Button
        android:id="@+id/btnAddToDb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="DODAJ DO BAZY" />


</LinearLayout>
</ScrollView>
    <ListView
        android:id="@+id/lvSneakers"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:dividerHeight="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/formScroll" />


</androidx.constraintlayout.widget.ConstraintLayout>